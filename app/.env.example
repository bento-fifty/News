# PostgreSQL connection string
# Local dev: get a free DB at https://neon.tech (free tier)
# Vercel deploy: use "Storage" tab → Create Postgres → copy DATABASE_URL
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# AI Summaries - get from https://console.anthropic.com
ANTHROPIC_API_KEY="your-key-here"

# YouTube Data API - get from https://console.cloud.google.com
YOUTUBE_API_KEY="your-key-here"

# Optional: protect the /api/ingest endpoint with a Bearer token
INGEST_SECRET="your-secret-here"
